<Window x:Class="RustPlusDesk.Views.PatchNotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rust+ Desk &#x2013; Patch Notes"
        Width="760" Height="640"
        MinWidth="620" MinHeight="520"
        Background="{DynamicResource AppBg}"
        Foreground="{DynamicResource TextPrimary}"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style x:Key="ReleaseCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceAlt}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="ReleaseTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="FeatureTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="FeatureText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSubtle}"/>
            <Setter Property="LineHeight" Value="18"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="OlderReleaseExpander" TargetType="Expander">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource Surface}"
            BorderBrush="{DynamicResource CardBorder}"
            BorderThickness="1"
            CornerRadius="{DynamicResource Radius}"
            Padding="18"
            Margin="8">
        <DockPanel LastChildFill="True">
            <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Patch Notes" FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock Text="Recent changes and version history"
                               Foreground="{DynamicResource TextSubtle}"
                               FontSize="12"
                               Margin="0,3,0,0"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#1A4A7A"
                        BorderBrush="#2A6AAA"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10,6"
                        VerticalAlignment="Top">
                    <TextBlock x:Name="TxtCurrentVersion"
                               Text="Current: v5.0.5"
                               Foreground="#A9D9FF"
                               FontWeight="SemiBold"
                               FontSize="12"/>
                </Border>
            </Grid>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Style="{StaticResource ReleaseCard}">
                        <StackPanel>
                            <TextBlock Text="v5.0.5 | Polish, private updates, and support links"
                                       Style="{StaticResource ReleaseTitle}"/>

                            <UniformGrid Columns="2" Margin="0,0,0,4">
                                <StackPanel Margin="0,0,14,0">
                                    <TextBlock Text="Private GitHub releases" Style="{StaticResource FeatureTitle}"/>
                                    <TextBlock Text="The update checker now supports a protected local GitHub token and gives clearer messages when a private release cannot be reached."
                                               Style="{StaticResource FeatureText}"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,0">
                                    <TextBlock Text="Cleaner patch notes" Style="{StaticResource FeatureTitle}"/>
                                    <TextBlock Text="The latest changes are easier to scan, and older history is grouped so the window opens on useful information first."
                                               Style="{StaticResource FeatureText}"/>
                                </StackPanel>
                            </UniformGrid>

                            <TextBlock Text="Support and community links now point to the current Discord invite."
                                       Foreground="{DynamicResource TextSubtle}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ReleaseCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Background="#101318"
                                    BorderBrush="{DynamicResource CardBorder}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="4"
                                    Margin="0,0,14,0">
                                <Image Source="pack://application:,,,/Assets/Images/RustPlus_V5_Thumbnail.jpg"
                                       Stretch="Uniform"
                                       MaxHeight="170"/>
                            </Border>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="v5.0.0 | The Game Changer Update"
                                           Style="{StaticResource ReleaseTitle}"/>

                                <TextBlock Text="Auto-update and runtime management" Style="{StaticResource FeatureTitle}"/>
                                <TextBlock Text="Background release checks, installer download progress, and centralized runtime handling for the Node.js listener."
                                           Style="{StaticResource FeatureText}"/>

                                <TextBlock Text="Modern map and interface work" Style="{StaticResource FeatureTitle}"/>
                                <TextBlock Text="A cleaner edge-to-edge layout, smoother player movement, map follow improvements, and a repaired center-on-map flow."
                                           Style="{StaticResource FeatureText}"/>

                                <TextBlock Text="Smarter devices and alerts" Style="{StaticResource FeatureTitle}"/>
                                <TextBlock Text="Storage Monitor detection, !Upkeep support, expanded chat alerts, Smart Alarm fixes, and FCM hardening."
                                           Style="{StaticResource FeatureText}"/>

                                <TextBlock Text="Player tracking upgrades" Style="{StaticResource FeatureTitle}"/>
                                <TextBlock Text="Rebuilt player cards with custom groups, colors, online state, play time, and a context menu."
                                           Style="{StaticResource FeatureText}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock Text="Earlier Releases"
                               Foreground="{DynamicResource Accent}"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Margin="0,6,0,8"/>

                    <Border Style="{StaticResource ReleaseCard}">
                        <StackPanel>
                            <Expander Style="{StaticResource OlderReleaseExpander}">
                                <Expander.Header>
                                    <TextBlock Text="v4.5.3 | Audio Smart Alert Hotfix" FontWeight="SemiBold"/>
                                </Expander.Header>
                                <StackPanel Margin="0,10,0,0">
                                    <Image Source="pack://application:,,,/Assets/Screenshots/4.5.0.png"
                                           Stretch="Uniform"
                                           MaxHeight="260"
                                           Margin="0,0,0,12"/>
                                    <TextBlock Text="Smart map follow and player tracking" Style="{StaticResource FeatureTitle}"/>
                                    <TextBlock Text="Follow yourself, teammates, or active events with smooth camera tracking."
                                               Style="{StaticResource FeatureText}"/>
                                    <TextBlock Text="Remote switch control" Style="{StaticResource FeatureTitle}"/>
                                    <TextBlock Text="Assign aliases to Smart Switches and toggle them from Team Chat commands."
                                               Style="{StaticResource FeatureText}"/>
                                    <TextBlock Text="Connection stability" Style="{StaticResource FeatureTitle}"/>
                                    <TextBlock Text="Clears stale device mappings on disconnect and reduces UI hangs while probing missing devices."
                                               Style="{StaticResource FeatureText}"/>
                                </StackPanel>
                            </Expander>

                            <Expander Style="{StaticResource OlderReleaseExpander}">
                                <Expander.Header>
                                    <TextBlock Text="v4.3.1 | Bugfixes and improvements" FontWeight="SemiBold"/>
                                </Expander.Header>
                                <StackPanel Margin="0,10,0,0">
                                    <TextBlock Text="Fixed marker drift when zooming, improved mini-map centering, added patrol helicopter crash detection, and hardened event reset logic when switching servers."
                                               Style="{StaticResource FeatureText}"/>
                                </StackPanel>
                            </Expander>

                            <Expander Style="{StaticResource OlderReleaseExpander}">
                                <Expander.Header>
                                    <TextBlock Text="v4.2 | Cargo Ship overhaul" FontWeight="SemiBold"/>
                                </Expander.Header>
                                <StackPanel Margin="0,10,0,0">
                                    <Image Source="pack://application:,,,/Assets/Screenshots/Cargo_notification_settings.png"
                                           Stretch="Uniform"
                                           MaxHeight="220"
                                           Margin="0,0,0,8"/>
                                    <TextBlock Text="Cargo route learning, live docking countdowns, granular cargo notifications, and synthetic Oil Rig crate triggers."
                                               Style="{StaticResource FeatureText}"/>
                                    <Border Background="#1A4A7A"
                                            BorderBrush="#2A6AAA"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="9"
                                            Margin="0,2,0,0">
                                        <TextBlock Text="Existing users should open Chat Alerts and reset their notification selection once with the master toggle."
                                                   Foreground="#A9D9FF"
                                                   TextWrapping="Wrap"/>
                                    </Border>
                                </StackPanel>
                            </Expander>

                            <Expander Style="{StaticResource OlderReleaseExpander}">
                                <Expander.Header>
                                    <TextBlock Text="v4.1.x | Notifications and custom crosshair" FontWeight="SemiBold"/>
                                </Expander.Header>
                                <StackPanel Margin="0,10,0,0">
                                    <TextBlock Text="Added granular notification management, improved map rendering at high zoom, and introduced the custom crosshair editor with PNG uploads."
                                               Style="{StaticResource FeatureText}"/>
                                </StackPanel>
                            </Expander>

                            <Expander Style="{StaticResource OlderReleaseExpander}">
                                <Expander.Header>
                                    <TextBlock Text="v4.0.0 | Map and stability overhaul" FontWeight="SemiBold"/>
                                </Expander.Header>
                                <StackPanel Margin="0,10,0,0">
                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,10">
                                        <Span Foreground="{DynamicResource TextSubtle}">Thanks to </Span>
                                        <Hyperlink NavigateUri="https://github.com/JawadYzbk"
                                                   RequestNavigate="Hyperlink_RequestNavigate"
                                                   Foreground="{DynamicResource Accent}">JawadYzbk</Hyperlink>
                                        <Span Foreground="{DynamicResource TextSubtle}"> for the core architecture rebuild.</Span>
                                    </TextBlock>
                                    <TextBlock Text="Predictive marker smoothing, the Event Dock, shop clustering, modern shop search, advanced trades, suspicious shop detection, smoother map animation, and offline item icon caching."
                                               Style="{StaticResource FeatureText}"/>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ReleaseCard}">
                        <StackPanel>
                            <TextBlock Text="Core Features and Older Updates"
                                       Style="{StaticResource ReleaseTitle}"/>
                            <TextBlock Text="v3.5.4: player management, renamed trackers, optimized item icon downloads, and progress tracking."
                                       Style="{StaticResource FeatureText}"/>
                            <TextBlock Text="v3.5.3: activity intelligence, manual Rust+ protocol links, tray mode, and improved BattleMetrics lookup."
                                       Style="{StaticResource FeatureText}"/>
                            <TextBlock Text="v3.4.0: hierarchical device grouping and persistent Smart Alarm settings."
                                       Style="{StaticResource FeatureText}"/>
                            <TextBlock Text="v3.3.x and earlier: Oil Rig timers, leader command support, storage monitor integration, shop analytics, team management, camera monitoring, and death markers."
                                       Style="{StaticResource FeatureText}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
