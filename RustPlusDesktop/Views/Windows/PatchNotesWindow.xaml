<Window x:Class="RustPlusDesk.Views.PatchNotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rust+ Desk &#x2013; Patch Notes"
        Width="760" Height="640"
        MinWidth="620" MinHeight="520"
        Background="{DynamicResource AppBg}"
        Foreground="{DynamicResource TextPrimary}"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style x:Key="ReleaseCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceAlt}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="ReleaseTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="FeatureTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="FeatureText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSubtle}"/>
            <Setter Property="LineHeight" Value="18"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

    </Window.Resources>

    <Border Background="{DynamicResource Surface}"
            BorderBrush="{DynamicResource CardBorder}"
            BorderThickness="1"
            CornerRadius="{DynamicResource Radius}"
            Padding="18"
            Margin="8">
        <DockPanel LastChildFill="True">
            <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Patch Notes" FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock Text="Recent changes and version history"
                               Foreground="{DynamicResource TextSubtle}"
                               FontSize="12"
                               Margin="0,3,0,0"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#1A4A7A"
                        BorderBrush="#2A6AAA"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10,6"
                        VerticalAlignment="Top">
                    <TextBlock x:Name="TxtCurrentVersion"
                               Text="Current: v5.0.10"
                               Foreground="#A9D9FF"
                               FontWeight="SemiBold"
                               FontSize="12"/>
                </Border>
            </Grid>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Style="{StaticResource ReleaseCard}">
                        <StackPanel>
                            <TextBlock Text="v5.0.10 | Connection fallback update"
                                       Style="{StaticResource ReleaseTitle}"/>

                            <UniformGrid Columns="2" Margin="0,0,0,4">
                                <StackPanel Margin="0,0,14,0">
                                    <TextBlock Text="Clearer connect errors" Style="{StaticResource FeatureTitle}"/>
                                    <TextBlock Text="Connection failures now explain whether the issue is token/pairing or timeout/network so fixes are easier."
                                               Style="{StaticResource FeatureText}"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,0">
                                    <TextBlock Text="Safer fallback behavior" Style="{StaticResource FeatureTitle}"/>
                                    <TextBlock Text="When direct returns not_found, the app skips pointless proxy retries and shows re-pair guidance."
                                               Style="{StaticResource FeatureText}"/>
                                </StackPanel>
                            </UniformGrid>

                            <TextBlock Text="This release improves Rust+ reconnect reliability and troubleshooting clarity."
                                       Foreground="{DynamicResource TextSubtle}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
