<Window x:Class="RustPlusDesk.Views.RustPlusToolsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rust++ Tools"
        Width="980"
        Height="640"
        MinWidth="820"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="#121417">
    <Window.Resources>
        <SolidColorBrush x:Key="AppBg" Color="#121417" />
        <SolidColorBrush x:Key="Surface" Color="#1C1F24" />
        <SolidColorBrush x:Key="SurfaceAlt" Color="#23272E" />
        <SolidColorBrush x:Key="CardBorder" Color="#33414850" />
        <SolidColorBrush x:Key="Accent" Color="#4FC3F7" />
        <SolidColorBrush x:Key="AccentDark" Color="#1E576F" />
        <SolidColorBrush x:Key="TextPrimary" Color="#ECEFF1" />
        <SolidColorBrush x:Key="TextSubtle" Color="#B0BEC5" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource SurfaceAlt}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}" />
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}" />
            <Setter Property="Padding" Value="8,5" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource SurfaceAlt}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}" />
            <Setter Property="Padding" Value="6,4" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentDark}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource Surface}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}" />
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="{StaticResource SurfaceAlt}" />
            <Setter Property="Padding" Value="10,5" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="Rust++ Tools" FontSize="24" FontWeight="SemiBold" />
                <TextBlock Text="Read-only item calculators and CCTV codes imported from the old Rust++ data set."
                           Foreground="{StaticResource TextSubtle}"
                           Margin="0,4,0,0" />
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource Surface}"
                    BorderBrush="{StaticResource CardBorder}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Search" FontSize="14" FontWeight="SemiBold" />
                        <Grid Margin="0,8,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SearchBox"
                                     Grid.Column="0"
                                     MinHeight="32"
                                     TextChanged="SearchBox_TextChanged"
                                     KeyDown="SearchBox_KeyDown" />
                            <Button Grid.Column="2"
                                    MinWidth="72"
                                    Click="Search_Click"
                                    Content="Search" />
                        </Grid>
                    </StackPanel>

                    <ListBox x:Name="ResultsList"
                             Grid.Row="1"
                             SelectionChanged="ResultsList_SelectionChanged" />

                    <Border Grid.Row="2"
                            Margin="0,10,0,0"
                            Background="{StaticResource SurfaceAlt}"
                            BorderBrush="{StaticResource CardBorder}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10">
                        <TextBlock x:Name="SelectedSummary"
                                   Text="No selection"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSubtle}" />
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="{StaticResource Surface}"
                    BorderBrush="{StaticResource CardBorder}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <TabControl>
                    <TabItem Header="Item">
                        <TextBox x:Name="ItemOutput"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" />
                    </TabItem>

                    <TabItem Header="Craft">
                        <DockPanel Margin="0,10,0,0">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Quantity" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBox x:Name="CraftQuantityBox" Width="70" Text="1" Margin="0,0,8,0" />
                                <Button Content="Calculate" Click="Craft_Click" />
                            </StackPanel>
                            <TextBox x:Name="CraftOutput" IsReadOnly="True" AcceptsReturn="True"
                                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" />
                        </DockPanel>
                    </TabItem>

                    <TabItem Header="Recycle">
                        <DockPanel Margin="0,10,0,0">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Quantity" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBox x:Name="RecycleQuantityBox" Width="70" Text="1" Margin="0,0,8,0" />
                                <ComboBox x:Name="RecyclerTypeBox" Width="160" SelectedIndex="0" Margin="0,0,8,0">
                                    <ComboBoxItem Content="recycler" />
                                    <ComboBoxItem Content="safe-zone-recycler" />
                                    <ComboBoxItem Content="shredder" />
                                </ComboBox>
                                <Button Content="Calculate" Click="Recycle_Click" />
                            </StackPanel>
                            <TextBox x:Name="RecycleOutput" IsReadOnly="True" AcceptsReturn="True"
                                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" />
                        </DockPanel>
                    </TabItem>

                    <TabItem Header="Research">
                        <DockPanel Margin="0,10,0,0">
                            <Button DockPanel.Dock="Top" Content="Refresh" HorizontalAlignment="Left"
                                    Margin="0,0,0,10" Click="Research_Click" />
                            <TextBox x:Name="ResearchOutput" IsReadOnly="True" AcceptsReturn="True"
                                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" />
                        </DockPanel>
                    </TabItem>

                    <TabItem Header="Decay">
                        <DockPanel Margin="0,10,0,0">
                            <Button DockPanel.Dock="Top" Content="Refresh" HorizontalAlignment="Left"
                                    Margin="0,0,0,10" Click="Decay_Click" />
                            <TextBox x:Name="DecayOutput" IsReadOnly="True" AcceptsReturn="True"
                                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" />
                        </DockPanel>
                    </TabItem>

                    <TabItem Header="Upkeep">
                        <DockPanel Margin="0,10,0,0">
                            <Button DockPanel.Dock="Top" Content="Refresh" HorizontalAlignment="Left"
                                    Margin="0,0,0,10" Click="Upkeep_Click" />
                            <TextBox x:Name="UpkeepOutput" IsReadOnly="True" AcceptsReturn="True"
                                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" />
                        </DockPanel>
                    </TabItem>

                    <TabItem Header="CCTV">
                        <DockPanel Margin="0,10,0,0">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Monument" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <ComboBox x:Name="CctvMonumentBox"
                                          Width="240"
                                          SelectionChanged="CctvMonumentBox_SelectionChanged" />
                            </StackPanel>
                            <TextBox x:Name="CctvOutput" IsReadOnly="True" AcceptsReturn="True"
                                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" />
                        </DockPanel>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </Grid>
</Window>
